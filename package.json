{
  "name": "ringbufkit",
  "version": "0.1.0",
  "description": "Zero-dependency typed Ring Buffer (circular buffer) — fixed-capacity FIFO, O(1) push/pop/peek, overwrite or throw on overflow. Inspired by Python deque(maxlen), Java ArrayDeque, C# CircularBuffer.",
  "keywords": [
    "ring-buffer",
    "circular-buffer",
    "ringbuffer",
    "deque",
    "fixed-capacity",
    "data-structure",
    "fifo",
    "typescript"
  ],
  "homepage": "https://github.com/trananhtung/ringbufkit#readme",
  "bugs": { "url": "https://github.com/trananhtung/ringbufkit/issues" },
  "repository": { "type": "git", "url": "git+https://github.com/trananhtung/ringbufkit.git" },
  "license": "MIT",
  "author": "trananhtung",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  }
}
